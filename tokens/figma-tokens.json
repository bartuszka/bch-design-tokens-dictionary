{
  "#core-color": {
    "white": {
      "$type": "color",
      "$value": "#ffffff"
    },
    "black": {
      "$type": "color",
      "$value": "#000000"
    },
    "neutral-300": {
      "$type": "color",
      "$value": "#333333"
    },
    "neutral-600": {
      "$type": "color",
      "$value": "#666666"
    },
    "neutral-900": {
      "$type": "color",
      "$value": "#999999"
    },
    "blue-300": {
      "$type": "color",
      "$value": "#3333ff"
    },
    "blue-600": {
      "$type": "color",
      "$value": "#6666ff"
    },
    "blue-900": {
      "$type": "color",
      "$value": "#9999ff"
    }
  },
  "#decision-color": {
    "text-color-primary": {
      "$type": "color",
      "$value": {
        "dark": "{#core-color.black}",
        "light": "{#core-color.neutral-900}"
      }
    },
    "text-color-secondary": {
      "$type": "color",
      "$value": {
        "dark": "{#core-color.white}",
        "light": "{#core-color.neutral-300}"
      }
    },
    "background-color": {
      "$type": "color",
      "$value": {
        "dark": "{#core-color.white}",
        "light": "{#core-color.neutral-300}"
      }
    },
    "header-color": {
      "$type": "color",
      "$value": {
        "dark": "{#core-color.blue-300}",
        "light": "{#core-color.blue-900}"
      }
    }
  },
  "$themes": [],
  "$metadata": {
    "tokenSetOrder": [
      "#core-color",
      "#decision-color"
    ]
  }
}